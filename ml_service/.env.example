# Vaidya Nidaan - ML / inference service (Flask) configuration
# Copy to ".env" and adjust. Every value has a sensible default; the service
# runs end-to-end even with none of these set.

# Port the Flask service listens on. The frontend expects 5001 by default.
PORT=5001

# Path to a trained Keras VGG-19 Alzheimer model (.h5/.keras). If unset or the
# file is missing, a deterministic NumPy fallback classifier is used instead so
# the pipeline still produces a result.
ALZHEIMER_MODEL_PATH=

# Root of an FSL installation (contains bin/fslstats, bin/bet, ...). Auto-detected
# from common locations (incl. ~/fsl) when left blank. Used for the biomarker
# report; the service falls back to image-intensity statistics if FSL is absent.
FSLDIR=

# OpenAI API key to enable the GPT-4-turbo multilingual RAG chatbot. When unset,
# an offline medical assistant answers locally so the chat still works.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo
