# Vaidya Nidaan - Backend (Node/Express) configuration
# Copy this file to ".env" and adjust as needed.

# Port the API gateway listens on. The frontend expects 5005 by default.
PORT=5005

# Secret used to sign JWTs. Any non-empty string works for local dev.
JWT_SECRET=vaidya_nidaan_dev_secret_change_me

# MongoDB connection string.
# Leave EMPTY to automatically start an in-memory MongoDB (mongodb-memory-server)
# so the app runs with zero external setup. Set this to a real mongodb:// URI
# (local mongod, Docker, or Atlas) if you want data to persist across restarts.
MONGO_URI=

# Base URL of the Python ML/inference service (Flask).
# Used only for the optional server-side health check / proxy.
ML_SERVICE_URL=http://localhost:5001
